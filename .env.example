# 管理者パスワード（ログイン用）
ADMIN_PASSWORD=your-admin-password

# GitHub API（問題データの commit に使用）
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=TakesSecHacLab-team
GITHUB_REPO=ExamServer
GITHUB_BRANCH=main

# アプリ内不具合報告 Issue に付けるラベル（任意）
BUG_REPORT_LABELS=bug,from-app

# アプリ内不具合報告 Issue の作成先（任意。未設定時は Vercel Git 情報または TakesSecHacLab-team/ExamServer）
GITHUB_ISSUE_OWNER=TakesSecHacLab-team
GITHUB_ISSUE_REPO=ExamServer
